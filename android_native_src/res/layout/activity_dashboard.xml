<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header Stats -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorPrimary"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Top Bar: Name, Chat, Reset -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        
                        <TextView
                            android:id="@+id/tvDashAssocName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الجمعية"
                            android:textColor="?attr/colorOnPrimary"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textStyle="bold"/>
                        
                        <!-- Dates Row -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">
                            <TextView
                                android:id="@+id/tvDashDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="01/2023"
                                android:textColor="?attr/colorOnPrimary"
                                android:alpha="0.9"
                                android:textAppearance="?attr/textAppearanceBodySmall"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" -> "
                                android:textColor="?attr/colorOnPrimary"
                                android:alpha="0.9"
                                android:layout_marginHorizontal="4dp"
                                android:textAppearance="?attr/textAppearanceBodySmall"/>
                            <TextView
                                android:id="@+id/tvDashEndDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10/2023"
                                android:textColor="?attr/colorOnPrimary"
                                android:alpha="0.9"
                                android:textAppearance="?attr/textAppearanceBodySmall"/>
                        </LinearLayout>
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnChat"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_chat"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="?attr/colorOnPrimary"
                        android:layout_marginEnd="8dp"
                        android:padding="12dp"/>

                    <Button
                        android:id="@+id/btnReset"
                        style="@style/Widget.Material3.Button.IconButton.Filled"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="R"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnError"
                        android:backgroundTint="?attr/colorError"/>
                </LinearLayout>

            <!-- Month Navigation Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:backgroundTint="#20FFFFFF"
                android:padding="4dp">

                <ImageButton
                    android:id="@+id/btnPrevMonth"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/colorOnPrimary"
                    android:contentDescription="الشهر السابق"/>

                <TextView
                    android:id="@+id/tvCurrentMonthDisplay"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="الشهر 1: يناير 2023"
                    android:textColor="?attr/colorOnPrimary"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <ImageButton
                    android:id="@+id/btnNextMonth"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_media_next"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/colorOnPrimary"
                    android:contentDescription="الشهر التالي"/>
            </LinearLayout>

                <!-- Money Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_height="wrap_content">
                        <TextView android:text="المحصل" android:textColor="?attr/colorOnPrimary" android:alpha="0.8" android:textAppearance="?attr/textAppearanceLabelMedium"/>
                        <TextView android:id="@+id/tvDashCollected" android:text="0.0" android:textColor="?attr/colorOnPrimary" android:textAppearance="?attr/textAppearanceHeadlineMedium" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="end"
                        android:layout_height="wrap_content">
                        <TextView android:text="المتبقي" android:textColor="?attr/colorOnPrimary" android:alpha="0.8" android:textAppearance="?attr/textAppearanceLabelMedium"/>
                        <TextView android:id="@+id/tvDashRemaining" android:text="0.0" android:textColor="?attr/colorOnPrimary" android:textAppearance="?attr/textAppearanceHeadlineSmall"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Member Count -->
                 <TextView
                    android:id="@+id/tvMemberCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عدد الأعضاء: 0"
                    android:textColor="?attr/colorOnPrimary"
                    android:alpha="0.8"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:layout_marginTop="8dp"
                    android:layout_gravity="end"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Recipient Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:text="مستلم هذا الشهر" android:textAppearance="?attr/textAppearanceLabelMedium" android:textColor="?attr/colorOnSurfaceVariant"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    
                    <TextView
                        android:id="@+id/tvRecipientName"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="اسم الشخص"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"/>

                    <CheckBox
                        android:id="@+id/cbPayoutDone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تسليم"
                        android:enabled="false"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- List Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="حالة الدفع للأعضاء"
                android:textColor="?attr/colorOnSurface"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textStyle="bold"/>

            <CheckBox
                android:id="@+id/cbSelectAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تحديد الكل"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDashMembers"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:clipToPadding="false"/>
    </LinearLayout>

    <!-- Floating Action Button for Adding Members -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddMember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="?attr/colorPrimaryContainer"
        app:tint="?attr/colorOnPrimaryContainer"
        android:contentDescription="Add Member" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>