<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#059669"
            android:padding="20dp"
            android:orientation="vertical"
            android:elevation="4dp">

            <!-- Top Bar: Name, Chat, Reset -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    
                    <TextView
                        android:id="@+id/tvDashAssocName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الجمعية"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                    
                    <!-- Dates Row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <TextView
                            android:id="@+id/tvDashDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="01/2023"
                            android:textColor="#E0F2F1"
                            android:textSize="12sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" -> "
                            android:textColor="#E0F2F1"
                            android:layout_marginHorizontal="4dp"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tvDashEndDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10/2023"
                            android:textColor="#E0F2F1"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnChat"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_chat"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    android:padding="8dp"/>

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="R"
                    android:textSize="10sp"
                    android:backgroundTint="#D32F2F"/>
            </LinearLayout>

            <!-- Money Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_height="wrap_content">
                    <TextView android:text="المحصل" android:textColor="#A7F3D0" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvDashCollected" android:text="0.0" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end"
                    android:layout_height="wrap_content">
                    <TextView android:text="المتبقي" android:textColor="#A7F3D0" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvDashRemaining" android:text="0.0" android:textColor="#FFFFFF" android:textSize="18sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Member Count -->
             <TextView
                android:id="@+id/tvMemberCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عدد الأعضاء: 0"
                android:textColor="#A7F3D0"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:layout_gravity="end"/>

        </LinearLayout>

        <!-- Recipient Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:layout_margin="16dp"
            android:padding="16dp"
            android:orientation="vertical"
            android:elevation="2dp">

            <TextView android:text="مستلم هذا الشهر" android:textSize="12sp" android:textColor="#6B7280"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                
                <TextView
                    android:id="@+id/tvRecipientName"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="اسم الشخص"
                    android:textSize="22sp"
                    android:textColor="#059669"
                    android:textStyle="bold"/>

                <CheckBox
                    android:id="@+id/cbPayoutDone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تسليم"
                    android:enabled="false"/>
            </LinearLayout>
        </LinearLayout>

        <!-- List Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="حالة الدفع للأعضاء"
                android:textColor="#374151"
                android:textStyle="bold"/>

            <CheckBox
                android:id="@+id/cbSelectAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تحديد الكل"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDashMembers"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:clipToPadding="false"/>
    </LinearLayout>

    <!-- Floating Action Button for Adding Members -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddMember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        android:src="@drawable/ic_add"
        android:backgroundTint="#059669"
        android:tint="#FFFFFF"
        android:contentDescription="Add Member" />

</RelativeLayout>