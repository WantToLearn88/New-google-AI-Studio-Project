<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardMemberDashboard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginHorizontal="4dp"
    app:cardElevation="1dp"
    app:cardCornerRadius="12dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:cardBackgroundColor="?attr/colorSurface"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Order, Name, Role Icon, Checkbox -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <!-- Order Badge -->
            <TextView
                android:id="@+id/tvMemberOrderBadge"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_circle_number"
                android:backgroundTint="?attr/colorSecondaryContainer"
                android:text="1"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:gravity="center"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/tvMemberDashName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="اسم العضو"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <!-- Bookmark Icon (Visible only for Recipient) -->
            <ImageView
                android:id="@+id/ivRoleBookmark"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_bookmark"
                android:layout_marginEnd="8dp"
                android:visibility="gone"
                app:tint="?attr/colorTertiary"
                android:contentDescription="الدور الحالي" />

            <CheckBox
                android:id="@+id/cbMemberPaid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleX="1.2"
                android:scaleY="1.2"
                android:buttonTint="?attr/colorPrimary" />
        </LinearLayout>

        <!-- Bottom Row: Date and Role Text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="44dp"> <!-- Indent to align with name -->
            
            <TextView
                android:id="@+id/tvMemberRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المستلم"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:background="?attr/colorTertiaryContainer"
                android:textColor="?attr/colorOnTertiaryContainer"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvMemberDashDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01/01/2023"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>