<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="8dp"
    android:elevation="1dp"
    android:background="@drawable/bg_card"
    android:layoutDirection="rtl">

    <!-- Top Row: Order, Name, Role Icon, Checkbox -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <!-- Order Badge -->
        <TextView
            android:id="@+id/tvMemberOrderBadge"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_circle_number"
            android:text="1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#374151"
            android:gravity="center"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvMemberDashName"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="اسم العضو"
            android:textSize="18sp"
            android:textColor="#1F2937"
            android:textStyle="bold" />

        <!-- Bookmark Icon (Visible only for Recipient) -->
        <ImageView
            android:id="@+id/ivRoleBookmark"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_bookmark"
            android:layout_marginEnd="8dp"
            android:visibility="gone"
            android:contentDescription="الدور الحالي" />

        <CheckBox
            android:id="@+id/cbMemberPaid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="1.2"
            android:scaleY="1.2"
            android:buttonTint="#059669" />
    </LinearLayout>

    <!-- Bottom Row: Date and Role Text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="44dp"> <!-- Indent to align with name -->
        
        <TextView
            android:id="@+id/tvMemberRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="المستلم"
            android:textSize="10sp"
            android:background="#FEF3C7"
            android:textColor="#D97706"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvMemberDashDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01/01/2023"
            android:textSize="13sp"
            android:textColor="#6B7280" />
    </LinearLayout>

</LinearLayout>